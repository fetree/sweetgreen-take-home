{
  "name": "mock-checkout-service",
  "version": "0.0.1",
  "description": "Checkout service with loyalty rewards integration",
  "scripts": {
    "start": "prisma migrate deploy && tsx prisma/seed.ts && tsx src/main.ts",
    "start:dev": "prisma migrate deploy && tsx prisma/seed.ts && tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "seed": "tsx prisma/seed.ts",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@nestjs/apollo": "^12.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "graphql": "^16.9.0",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
